# Azure AI Foundry / Azure OpenAI
# Authentication is via Microsoft Entra ID using DefaultAzureCredential
# (Principle IV). Sign in locally with `az login` or set the env vars
# for AZURE_CLIENT_ID / AZURE_TENANT_ID / managed identity in production.
AZURE_OPENAI_ENDPOINT=https://obi-openai-test.azure-api.net/oai/v1/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# MomDiary
MOMDIARY_DB_URL=sqlite+aiosqlite:///./momdiary.db
MOMDIARY_DEFAULT_TIMEZONE=America/Los_Angeles
MOMDIARY_APP_ENV=dev

# Comma-separated allow-list for browser origins (CORS). The Vite dev server
# defaults to 5173; production deployments should override this.
MOMDIARY_ALLOWED_ORIGINS=http://localhost:5173

# Chat session store (feature 003). All values are env-tunable; defaults shown.
MOMDIARY_SESSION_TTL_SECONDS=86400
MOMDIARY_SESSION_MAX_TURNS=50
MOMDIARY_SESSION_MAX_SESSIONS=100
MOMDIARY_SESSION_MESSAGE_MAX_BYTES=4096
MOMDIARY_SESSION_PROMPT_TOKEN_BUDGET=12000
