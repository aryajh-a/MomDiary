# Azure AI Foundry / Azure OpenAI
# Authentication is via Microsoft Entra ID using DefaultAzureCredential
# (Principle IV). Sign in locally with `az login` or set the env vars
# for AZURE_CLIENT_ID / AZURE_TENANT_ID / managed identity in production.
AZURE_OPENAI_ENDPOINT=https://openai-api.net/oai/v1/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-10-21

# MomDiary
# Feature 009 — Postgres is the single datastore. Pick ONE of:
#   * Local Postgres (docker run -p 5432:5432 postgres:16): use ssl=disable
#   * Azure Postgres Flex:
#     postgresql+asyncpg://<user>:<password>@abc.postgres.database.azure.com:5432/<db>?ssl=require
MOMDIARY_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/momdiary?ssl=disable
# When set, pytest fixtures use this URL instead of MOMDIARY_DB_URL so test
# data is isolated from dev data. Leave blank to reuse MOMDIARY_DB_URL.
MOMDIARY_TEST_DB_URL=
# Async pool sizing for asyncpg (Azure Postgres B1ms cap ≈ 50 connections).
MOMDIARY_DB_POOL_SIZE=5
MOMDIARY_DB_MAX_OVERFLOW=5
MOMDIARY_DEFAULT_TIMEZONE=America/Los_Angeles
MOMDIARY_APP_ENV=dev

# Comma-separated allow-list for browser origins (CORS). The Vite dev server
# defaults to 5173; production deployments should override this.
MOMDIARY_ALLOWED_ORIGINS=http://localhost:5173

# Chat session store (feature 003 + 009). Defaults shown.
MOMDIARY_SESSION_STORE=postgres          # one of: postgres | memory
MOMDIARY_SESSION_TTL_SECONDS=86400
MOMDIARY_SESSION_MAX_TURNS=50
MOMDIARY_SESSION_MAX_SESSIONS=100
MOMDIARY_SESSION_MESSAGE_MAX_BYTES=4096
MOMDIARY_SESSION_PROMPT_TOKEN_BUDGET=12000
MOMDIARY_SESSION_SWEEP_INTERVAL_SECONDS=600
